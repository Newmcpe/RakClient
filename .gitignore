/target
# OMC session/operational state (must not be committed)
/.omc/
# parallel implementation worktrees (provisioned via `git worktree add`)
/.wt/
# Serena language-server tool state
/.serena/
# JetBrains IDE project files
/.idea/
# local-only auto-loaded scripts dir (holds private credentials)
/scripts/
# auto-loaded SOCKS5 proxy spec (holds proxy credentials)
/proxy.txt
# generated navmesh / baked-scene / capture-extract artifacts (regenerate from the tools)
*.nav
*.scene
/objects.csv
/out207.txt
**/*.rs.bk
Cargo.lock.bak
*.pdb
.DS_Store
# keep IDA database out of the repo
*.i64
*.idb
*.id0
*.id1
*.id2
*.nam
*.til
